{
  "name": "lea",
  "productName": "Lea",
  "version": "0.1.1",
  "description": "Lea — a cross-platform menu-bar/tray app that tracks your Claude usage and autonomously runs a to-do queue the moment your limit resets, so Claude works while you sleep.",
  "main": "src/main.js",
  "author": "Lea contributors",
  "license": "MIT",
  "homepage": "https://github.com/bobby33400/Lea#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bobby33400/Lea.git"
  },
  "bugs": {
    "url": "https://github.com/bobby33400/Lea/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "automation",
    "agent",
    "menubar",
    "tray",
    "electron",
    "task-queue",
    "tokens"
  ],
  "scripts": {
    "start": "electron .",
    "selftest": "node scripts/selftest.js",
    "make:icon": "node scripts/make-app-icon.js",
    "check": "node --check src/main.js && node --check src/runner.js && node --check src/usage.js && node --check src/store.js && node --check src/sandbox.js && node --check src/classify.js && node --check src/config.js && node --check src/icon.js && node --check src/spawnutil.js && node --check src/preload.js && node --check src/renderer/app.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "ccusage": "^20.0.0",
    "cross-spawn": "^7.0.6",
    "menubar": "^9.5.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.lea.app",
    "productName": "Lea",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    }
  }
}
